		function randomCardNumbers() {
			const available = Array.from({ length: 75 }, (_, index) => index + 1);
			for (let index = available.length - 1; index > 0; index -= 1) {
				const swapIndex = Math.floor(Math.random() * (index + 1));
				[available[index], available[swapIndex]] = [available[swapIndex], available[index]];
			}
			const selectedNumbers = available.slice(0, ACTIVE_CARD_SIZE);
			let selectedIndex = 0;
			return ALL_INDEXES.map((index) =>
				index === CENTER_INDEX ? null : selectedNumbers[selectedIndex++],
			);
		}

		function uniquePattern(pattern) {
			return [...new Set(pattern)];
		}

		function currentBingoTypeKey() {
			return BINGO_TYPES[state.bingoType] ? state.bingoType : 'full';
		}

		function currentBingoType() {
			if (currentBingoTypeKey() === CUSTOM_TYPE_KEY) {
				return {
					...BINGO_TYPES[CUSTOM_TYPE_KEY],
					patterns: [normalizeCustomPattern(state.customPattern)],
				};
			}

			return BINGO_TYPES[currentBingoTypeKey()];
		}

		function patternProgress(card, drawnSet, pattern) {
			const indexes = uniquePattern(pattern).filter((index) => index !== CENTER_INDEX);
			const matched = indexes.filter((index) => drawnSet.has(card.numbers[index])).length;
			return {
				indexes,
				matched,
				required: indexes.length,
				isComplete: matched === indexes.length,
			};
		}

		function cardStatus(card, drawnSet) {
			const type = currentBingoType();
			const patternResults = type.patterns
				.map((pattern) => patternProgress(card, drawnSet, pattern))
				.sort((first, second) => {
					if (second.matched !== first.matched) return second.matched - first.matched;
					return second.matched / second.required - first.matched / first.required;
				});
			const winningPattern = patternResults.find((pattern) => pattern.isComplete);
			const bestPattern = winningPattern ?? patternResults[0];

			return {
				isBingo: Boolean(winningPattern),
				label: winningPattern ? type.winLabel : `${bestPattern.matched}/${bestPattern.required}`,
				marked: ACTIVE_INDEXES.filter((index) => drawnSet.has(card.numbers[index])).length,
				patternIndexes: bestPattern.indexes,
				typeLabel: type.label,
				winLabel: type.winLabel,
			};
		}

		function winningEntries(drawnSet) {
			return state.cards
				.map((card) => ({ card, status: cardStatus(card, drawnSet) }))
				.filter((entry) => entry.status.isBingo);
		}

		function winnerKey(card) {
			return `${currentBingoTypeKey()}::${card.id}`;
		}

		function renderBingoType() {
			const typeKey = currentBingoTypeKey();
			const type = currentBingoType();
			const previewIndexes = new Set(uniquePattern(type.patterns[0]));

			bingoTypeSelect.value = typeKey;
			bingoTypeLabel.textContent = type.label;
			bingoTypeRequirement.textContent = `${previewIndexes.size} casillas`;
			editCustomPatternButton.classList.toggle('hidden', typeKey !== CUSTOM_TYPE_KEY);
			patternPreview.innerHTML = ALL_INDEXES.map((index) => {
				const isDisabled = index === CENTER_INDEX;
				const isActive = previewIndexes.has(index);
				const classes = isDisabled
					? 'border-slate-200 bg-slate-100'
					: isActive
						? 'border-emerald-600 bg-emerald-600'
						: 'border-slate-200 bg-slate-50';
				return `
					<div class="aspect-square rounded-sm border ${classes}"></div>
				`;
			}).join('');
		}

		function renderBingoSound() {
			const customSound = normalizeBingoSound(state.bingoSound);
			const sound = effectiveBingoSound();
			bingoSoundStatus.textContent = customSound ? sound.name : `${sound.name} por defecto`;
			testBingoSoundButton.disabled = false;
			removeBingoSoundButton.disabled = !customSound;
		}

		function patternPositionLabel(index) {
			const column = CARD_COLUMNS[index % CARD_COLUMNS.length];
			const row = Math.floor(index / CARD_COLUMNS.length) + 1;
			return `${column}${row}`;
		}

		function setCustomPatternError(message) {
			customPatternError.textContent = message;
			customPatternError.classList.toggle('hidden', !message);
		}

		function renderCustomPatternGrid() {
			const selectedIndexes = new Set(customPatternDraft);
			customPatternCount.textContent = `${selectedIndexes.size} casillas`;
			customPatternGrid.innerHTML = ALL_INDEXES.map((index) => {
				if (index === CENTER_INDEX) {
					return controlCellMarkup('Centro', 'is-card-cell');
				}

				const isSelected = selectedIndexes.has(index);
				return `
					<button
						class="custom-pattern-cell ${isSelected ? 'is-selected' : ''}"
						type="button"
						data-custom-pattern-index="${index}"
						aria-pressed="${isSelected}"
					>
						${patternPositionLabel(index)}
					</button>
				`;
			}).join('');
		}

		function openCustomPatternModal() {
			customPatternDraft = normalizeCustomPattern(state.customPattern);
			setCustomPatternError('');
			renderCustomPatternGrid();
			customPatternModal.classList.remove('hidden');
			document.body.classList.add('overflow-hidden');
		}

		function closeCustomPatternModal() {
			customPatternModal.classList.add('hidden');
			document.body.classList.remove('overflow-hidden');
			customPatternDraft = [];
			renderBingoType();
		}

		function saveCustomPattern() {
			if (customPatternDraft.length === 0) {
				setCustomPatternError('Selecciona al menos una casilla.');
				return;
			}

			state.customPattern = normalizeCustomPattern(customPatternDraft);
			state.bingoType = CUSTOM_TYPE_KEY;
			hasRendered = false;
			saveState();
			closeCustomPatternModal();
			render();
		}

		function audioFileToDataUrl(file) {
			return new Promise((resolve, reject) => {
				const reader = new FileReader();
				reader.addEventListener('load', () => resolve(String(reader.result)));
				reader.addEventListener('error', () => reject(reader.error));
				reader.readAsDataURL(file);
			});
		}

		function dataUrlToArrayBuffer(dataUrl) {
			const base64 = dataUrl.split(',')[1] ?? '';
			const binary = window.atob(base64);
			const bytes = new Uint8Array(binary.length);
			for (let index = 0; index < binary.length; index += 1) {
				bytes[index] = binary.charCodeAt(index);
			}
			return bytes.buffer;
		}

		function getStudioAudioContext() {
			const AudioContext = window.AudioContext || window.webkitAudioContext;
			if (!studioAudioContext) {
				studioAudioContext = new AudioContext();
			}
			return studioAudioContext;
		}

		async function decodeAudioDataUrl(dataUrl) {
			const audioContext = getStudioAudioContext();
			const arrayBuffer = dataUrlToArrayBuffer(dataUrl);
			return audioContext.decodeAudioData(arrayBuffer.slice(0));
		}

		function stopStudioPlayback() {
			if (!studioAudioSource) return;
			try {
				studioAudioSource.stop();
			} catch {
				// The source may already have ended.
			}
			studioAudioSource = null;
			stopStudioPlaybackProgress();
		}

		async function playSoundSegment(sound, options = {}) {
			const audioContext = getStudioAudioContext();
			if (audioContext.state === 'suspended') {
				await audioContext.resume();
			}

			const buffer = await decodeAudioDataUrl(sound.dataUrl);
			const source = audioContext.createBufferSource();
			const trimStart = Math.max(0, Number(sound.trimStart) || 0);
			const trimEnd = Number(sound.trimEnd);
			const end = Number.isFinite(trimEnd) && trimEnd > trimStart ? Math.min(trimEnd, buffer.duration) : buffer.duration;
			const requestedStart = Number(options.startAt);
			const start = Number.isFinite(requestedStart)
				? Math.min(Math.max(requestedStart, trimStart), Math.max(trimStart, end - 0.05))
				: trimStart;
			const duration = Math.max(0.05, end - start);
			const playbackRate = Number(sound.playbackRate) || 1;
			const shouldTrackStudio = options.trackStudio !== false;

			if (shouldTrackStudio) {
				stopStudioPlayback();
			}
			source.buffer = buffer;
			source.playbackRate.value = playbackRate;
			source.connect(audioContext.destination);
			source.addEventListener('ended', () => {
				if (studioAudioSource === source) {
					studioAudioSource = null;
					stopStudioPlaybackProgress();
				}
				options.onEnded?.();
			});
			if (shouldTrackStudio) {
				studioAudioSource = source;
			}
			source.start(0, start, duration);
			return { source, start, duration, playbackRate, buffer };
		}

		function hasSoundEdits(sound) {
			return (
				Number.isFinite(Number(sound.trimStart)) ||
				Number.isFinite(Number(sound.trimEnd)) ||
				(Number.isFinite(Number(sound.playbackRate)) && Number(sound.playbackRate) !== 1)
			);
		}

		function playBingoSound() {
			const sound = effectiveBingoSound();
			if (!sound) return;

			if (sound.dataUrl && hasSoundEdits(sound)) {
				playSoundSegment(sound, { trackStudio: false }).catch(() => {
					setBingoSoundError('No se pudo reproducir el sonido. Prueba tocar "Probar" una vez.');
				});
				return;
			}

			const audio = new Audio(sound.dataUrl ?? sound.src);
			audio.play().catch(() => {
				setBingoSoundError('No se pudo reproducir el sonido. Prueba tocar "Probar" una vez.');
			});
		}

		function formatSeconds(value) {
			const seconds = Number(value) || 0;
			return `${seconds.toFixed(1)}s`;
		}

		function waveformContext() {
			return soundWaveformCanvas.getContext('2d');
		}

		function drawEmptyWaveform(label = 'Graba o carga una vista previa') {
			const canvas = soundWaveformCanvas;
			const context = waveformContext();
			const width = canvas.width;
			const height = canvas.height;
			context.clearRect(0, 0, width, height);
			context.fillStyle = '#f8fafc';
			context.fillRect(0, 0, width, height);
			context.strokeStyle = '#cbd5e1';
			context.lineWidth = 2;
			context.beginPath();
			context.moveTo(0, height / 2);
			context.lineTo(width, height / 2);
			context.stroke();
			context.fillStyle = '#64748b';
			context.font = '700 16px system-ui';
			context.textAlign = 'center';
			context.fillText(label, width / 2, height / 2 - 14);
		}

		function drawWaveform(buffer, progress = 0) {
			if (!buffer) {
				drawEmptyWaveform();
				return;
			}

			const canvas = soundWaveformCanvas;
			const context = waveformContext();
			const width = canvas.width;
			const height = canvas.height;
			const data = buffer.getChannelData(0);
			const bars = 120;
			const samplesPerBar = Math.max(1, Math.floor(data.length / bars));
			const trimStart = Number(studioDraft?.trimStart) || 0;
			const trimEnd = Number(studioDraft?.trimEnd) || buffer.duration;
			const selectedStartRatio = buffer.duration ? trimStart / buffer.duration : 0;
			const selectedEndRatio = buffer.duration ? trimEnd / buffer.duration : 1;

			context.clearRect(0, 0, width, height);
			context.fillStyle = '#f8fafc';
			context.fillRect(0, 0, width, height);
			context.fillStyle = '#e2e8f0';
			context.fillRect(selectedStartRatio * width, 0, (selectedEndRatio - selectedStartRatio) * width, height);

			for (let bar = 0; bar < bars; bar += 1) {
				let peak = 0;
				const start = bar * samplesPerBar;
				const end = Math.min(start + samplesPerBar, data.length);
				for (let index = start; index < end; index += 1) {
					peak = Math.max(peak, Math.abs(data[index]));
				}

				const x = (bar / bars) * width;
				const barWidth = Math.max(2, width / bars - 2);
				const barHeight = Math.max(4, peak * (height - 24));
				const ratio = bar / bars;
				context.fillStyle = ratio >= selectedStartRatio && ratio <= selectedEndRatio ? '#059669' : '#94a3b8';
				context.fillRect(x, (height - barHeight) / 2, barWidth, barHeight);
			}

			if (progress > 0) {
				const progressX = Math.min(width, Math.max(0, progress * width));
				context.strokeStyle = '#f59e0b';
				context.lineWidth = 4;
				context.beginPath();
				context.moveTo(progressX, 0);
				context.lineTo(progressX, height);
				context.stroke();
			}
		}

		function stopStudioMeter() {
			if (studioMeterAnimation) {
				cancelAnimationFrame(studioMeterAnimation);
				studioMeterAnimation = null;
			}
			if (studioMeterSource) {
				studioMeterSource.disconnect();
				studioMeterSource = null;
			}
			studioAnalyser = null;
		}

		function drawRecordingMeter() {
			if (!studioAnalyser || !studioIsRecording()) return;

			const canvas = soundWaveformCanvas;
			const context = waveformContext();
			const width = canvas.width;
			const height = canvas.height;
			const data = new Uint8Array(studioAnalyser.fftSize);
			studioAnalyser.getByteTimeDomainData(data);

			context.clearRect(0, 0, width, height);
			context.fillStyle = '#f8fafc';
			context.fillRect(0, 0, width, height);
			context.strokeStyle = '#059669';
			context.lineWidth = 3;
			context.beginPath();

			data.forEach((value, index) => {
				const x = (index / (data.length - 1)) * width;
				const y = (value / 255) * height;
				if (index === 0) {
					context.moveTo(x, y);
				} else {
					context.lineTo(x, y);
				}
			});
			context.stroke();

			const elapsed = (performance.now() - studioRecordingStartedAt) / 1000;
			studioTimelineInput.max = '60';
			studioTimelineInput.value = String(Math.min(elapsed, 60));
			studioTimeLabel.textContent = formatSeconds(elapsed);
			studioMeterAnimation = requestAnimationFrame(drawRecordingMeter);
		}

		function startStudioPlaybackProgress(start, duration, playbackRate, buffer) {
			if (studioPlaybackAnimation) {
				cancelAnimationFrame(studioPlaybackAnimation);
			}

			studioPlaybackStartedAt = performance.now();
			studioPlaybackStart = start;
			studioPlaybackDuration = duration;

			const tick = () => {
				if (!studioAudioSource) return;
				const elapsed = ((performance.now() - studioPlaybackStartedAt) / 1000) * playbackRate;
				const current = Math.min(studioPlaybackStart + elapsed, studioPlaybackStart + studioPlaybackDuration);
				studioTimelineInput.value = String(current);
				studioTimeLabel.textContent = `${formatSeconds(current)} / ${formatSeconds(buffer.duration)}`;
				drawWaveform(buffer, current / buffer.duration);
				studioPlaybackAnimation = requestAnimationFrame(tick);
			};

			tick();
		}

		function stopStudioPlaybackProgress() {
			if (studioPlaybackAnimation) {
				cancelAnimationFrame(studioPlaybackAnimation);
				studioPlaybackAnimation = null;
			}
		}

		function setSoundStudioError(message) {
			soundStudioError.textContent = message;
			soundStudioError.classList.toggle('hidden', !message);
		}

		function stopStudioStream() {
			if (!studioStream) return;
			studioStream.getTracks().forEach((track) => track.stop());
			studioStream = null;
		}

		function studioIsRecording() {
			return studioRecorder?.state === 'recording';
		}

		function renderSoundStudio() {
			const hasDraft = Boolean(studioDraft?.dataUrl);
			const isRecording = studioIsRecording();
			const isPlaying = Boolean(studioAudioSource);
			const isBusy = isRecording || studioIsProcessing || isPlaying;
			const duration = hasDraft ? Number(studioDraft.duration) || 0 : 0;
			const trimStart = hasDraft ? Math.min(Number(studioDraft.trimStart) || 0, duration) : 0;
			const trimEnd = hasDraft ? Math.min(Number(studioDraft.trimEnd) || duration, duration) : 0;
			const playbackRate = hasDraft ? Number(studioDraft.playbackRate) || 1 : 1;
			const currentTimelineValue = Number(studioTimelineInput.value);
			const timelineValue = hasDraft
				? Math.min(Math.max(Number.isFinite(currentTimelineValue) ? currentTimelineValue : trimStart, trimStart), trimEnd || duration)
				: 0;

			soundStudioStatus.textContent = isRecording
				? 'Grabando...'
				: hasDraft
					? 'Grabación lista'
					: 'Sin grabación';
			soundStudioDetail.textContent = hasDraft
				? `Duración ${formatSeconds(duration)}`
				: 'Graba un audio corto para usarlo cuando salga Bingo.';
			if (studioIsProcessing) {
				soundStudioStatus.textContent = 'Preparando audio...';
			}
			if (hasDraft) {
				soundStudioDetail.textContent = `Duración ${formatSeconds(duration)} · tramo ${formatSeconds(trimStart)}-${formatSeconds(trimEnd)} · ${playbackRate.toFixed(2)}x`;
			}

			startRecordingButton.disabled = isBusy;
			stopRecordingButton.disabled = !isRecording;
			playRecordingButton.disabled = !hasDraft || isRecording || studioIsProcessing;
			resetRecordingButton.disabled = !hasDraft || isBusy;
			saveSoundStudioButton.disabled = !hasDraft || isBusy;

			trimStartInput.disabled = !hasDraft || isBusy;
			trimEndInput.disabled = !hasDraft || isBusy;
			soundSpeedInput.disabled = !hasDraft || isBusy;
			studioTimelineInput.disabled = !hasDraft || isRecording || studioIsProcessing;

			trimStartInput.max = String(duration);
			trimEndInput.max = String(duration);
			trimStartInput.value = String(trimStart);
			trimEndInput.value = String(trimEnd);
			soundSpeedInput.value = String(playbackRate);
			studioTimelineInput.max = String(duration);
			studioTimelineInput.value = String(timelineValue);

			trimStartLabel.textContent = formatSeconds(trimStart);
			trimEndLabel.textContent = formatSeconds(trimEnd);
			soundSpeedLabel.textContent = `${playbackRate.toFixed(2)}x`;
			studioTimeLabel.textContent = hasDraft
				? `${formatSeconds(timelineValue)} / ${formatSeconds(duration)}`
				: '0.0s';
			playRecordingIcon.classList.toggle('hidden', isPlaying);
			pauseRecordingIcon.classList.toggle('hidden', !isPlaying);
			playRecordingLabel.textContent = isPlaying ? 'Pausar' : 'Reproducir';

			if (isRecording) return;
			if (hasDraft && studioWaveformBuffer) {
				drawWaveform(studioWaveformBuffer, duration ? timelineValue / duration : 0);
				return;
			}
			drawEmptyWaveform(studioIsProcessing ? 'Preparando forma de onda...' : undefined);
		}

		function openSoundStudio() {
			setSoundStudioError('');
			const existingSound = normalizeBingoSound(state.bingoSound);
			studioDraft = existingSound?.kind === 'recorded' ? { ...existingSound } : null;
			studioWaveformBuffer = null;
			studioIsProcessing = Boolean(studioDraft?.dataUrl);
			soundStudioModal.classList.remove('hidden');
			document.body.classList.add('overflow-hidden');
			renderSoundStudio();
			if (!studioDraft?.dataUrl) return;

			const draftDataUrl = studioDraft.dataUrl;
			decodeAudioDataUrl(draftDataUrl)
				.then((buffer) => {
					if (studioDraft?.dataUrl !== draftDataUrl) return;
					studioWaveformBuffer = buffer;
					studioDraft.duration = Number(studioDraft.duration) || buffer.duration;
					studioDraft.trimEnd = Number(studioDraft.trimEnd) || buffer.duration;
					studioIsProcessing = false;
					renderSoundStudio();
				})
				.catch(() => {
					studioIsProcessing = false;
					setSoundStudioError('No se pudo preparar la forma de onda.');
					renderSoundStudio();
				});
		}

		function closeSoundStudio() {
			if (studioIsRecording()) {
				studioRecorder.stop();
			}
			stopStudioPlayback();
			stopStudioMeter();
			stopStudioStream();
			studioRecorder = null;
			studioChunks = [];
			studioDraft = null;
			studioWaveformBuffer = null;
			studioIsProcessing = false;
			soundStudioModal.classList.add('hidden');
			document.body.classList.remove('overflow-hidden');
			setSoundStudioError('');
		}

		async function startStudioRecording() {
			setSoundStudioError('');
			if (!navigator.mediaDevices?.getUserMedia || !window.MediaRecorder) {
				setSoundStudioError('Tu navegador no permite grabar audio desde esta pantalla.');
				return;
			}

			try {
				stopStudioPlayback();
				stopStudioMeter();
				studioWaveformBuffer = null;
				studioStream = await navigator.mediaDevices.getUserMedia({ audio: true });
				studioChunks = [];
				const audioContext = getStudioAudioContext();
				if (audioContext.state === 'suspended') {
					await audioContext.resume();
				}
				studioAnalyser = audioContext.createAnalyser();
				studioAnalyser.fftSize = 2048;
				studioMeterSource = audioContext.createMediaStreamSource(studioStream);
				studioMeterSource.connect(studioAnalyser);
				const preferredType = MediaRecorder.isTypeSupported('audio/webm;codecs=opus')
					? 'audio/webm;codecs=opus'
					: '';
				studioRecorder = new MediaRecorder(
					studioStream,
					preferredType ? { mimeType: preferredType } : undefined,
				);
				studioRecorder.addEventListener('dataavailable', (event) => {
					if (event.data.size > 0) {
						studioChunks.push(event.data);
					}
				});
				studioRecorder.addEventListener('stop', async () => {
					const blob = new Blob(studioChunks, { type: studioRecorder?.mimeType || 'audio/webm' });
					stopStudioMeter();
					stopStudioStream();
					studioRecorder = null;
					studioChunks = [];

					try {
						const dataUrl = await audioFileToDataUrl(blob);
						studioWaveformBuffer = await decodeAudioDataUrl(dataUrl);
						const duration = studioWaveformBuffer.duration;
						studioDraft = {
							name: 'Sonido grabado',
							dataUrl,
							kind: 'recorded',
							duration,
							trimStart: 0,
							trimEnd: duration,
							playbackRate: 1,
						};
					} catch {
						setSoundStudioError('No se pudo preparar la grabación.');
					}

					studioIsProcessing = false;
					renderSoundStudio();
				});
				studioRecorder.start();
				studioDraft = null;
				studioIsProcessing = false;
				studioRecordingStartedAt = performance.now();
				renderSoundStudio();
				drawRecordingMeter();
			} catch {
				stopStudioMeter();
				stopStudioStream();
				studioRecorder = null;
				studioIsProcessing = false;
				setSoundStudioError('No se pudo acceder al micrófono.');
				renderSoundStudio();
			}
		}

		function stopStudioRecording() {
			if (!studioIsRecording()) return;
			studioIsProcessing = true;
			studioRecorder.stop();
			stopStudioMeter();
			renderSoundStudio();
		}

		function updateStudioTrim(changedField) {
			if (!studioDraft) return;
			const duration = Number(studioDraft.duration) || 0;
			let start = Number(trimStartInput.value) || 0;
			let end = Number(trimEndInput.value) || duration;

			if (changedField === 'start' && start >= end) {
				start = Math.max(0, end - 0.05);
			}
			if (changedField === 'end' && end <= start) {
				end = Math.min(duration, start + 0.05);
			}

			studioDraft.trimStart = Math.max(0, Math.min(start, duration));
			studioDraft.trimEnd = Math.max(studioDraft.trimStart + 0.05, Math.min(end, duration));
			studioTimelineInput.value = String(studioDraft.trimStart);
			renderSoundStudio();
		}

		function updateStudioSpeed() {
			if (!studioDraft) return;
			studioDraft.playbackRate = Number(soundSpeedInput.value) || 1;
			renderSoundStudio();
		}

		function playStudioDraft() {
			if (!studioDraft?.dataUrl) return;
			setSoundStudioError('');
			if (studioAudioSource) {
				stopStudioPlayback();
				renderSoundStudio();
				return;
			}

			const startAt = Number(studioTimelineInput.value) || Number(studioDraft.trimStart) || 0;
			playSoundSegment(studioDraft, {
				startAt,
				onEnded: () => {
					stopStudioPlaybackProgress();
					studioTimelineInput.value = String(Number(studioDraft?.trimStart) || 0);
					renderSoundStudio();
				},
			}).then((result) => {
				studioWaveformBuffer = result.buffer;
				startStudioPlaybackProgress(result.start, result.duration, result.playbackRate, result.buffer);
				renderSoundStudio();
			}).catch(() => {
				setSoundStudioError('No se pudo reproducir la grabación.');
				renderSoundStudio();
			});
		}

		function resetStudioDraft() {
			stopStudioPlayback();
			studioDraft = null;
			studioWaveformBuffer = null;
			studioIsProcessing = false;
			setSoundStudioError('');
			renderSoundStudio();
		}

		function saveSoundStudio() {
			if (!studioDraft?.dataUrl) {
				setSoundStudioError('Primero graba un sonido.');
				return;
			}

			const previousSound = state.bingoSound;
			state.bingoSound = normalizeBingoSound(studioDraft);
			if (!saveState()) {
				state.bingoSound = previousSound;
				setSoundStudioError('La grabación es muy grande para guardarla. Intenta una más corta.');
				return;
			}

			closeSoundStudio();
			setBingoSoundError('');
			renderBingoSound();
		}

		function renderSummary() {
			const drawnSet = new Set(state.drawnNumbers);
			const winners = winningEntries(drawnSet).length;
			const items = [
				['Cartillas', state.cards.length],
				['Cantados', state.drawnNumbers.length],
				['Bingos', winners],
			];

			summary.innerHTML = items
				.map(
					([label, value]) => `
						<div class="rounded-lg border border-slate-200 bg-slate-50 px-3 py-2 text-center">
							<p class="text-xl font-black text-slate-950">${value}</p>
							<p class="text-xs font-bold uppercase tracking-wide text-slate-500">${label}</p>
						</div>
					`,
				)
				.join('');
		}

		function renderDrawnNumbers() {
			lastDrawn.textContent = state.drawnNumbers.at(-1) ?? '-';
			undoDrawButton.disabled = state.drawnNumbers.length === 0;
			clearDrawsButton.disabled = state.drawnNumbers.length === 0;

			if (state.drawnNumbers.length === 0) {
				drawnList.innerHTML = '<p class="text-sm font-medium text-slate-500">Sin números cantados</p>';
				return;
			}

			drawnList.innerHTML = state.drawnNumbers
				.map(
					(number) => `
						<button class="rounded-md border border-slate-200 bg-slate-950 px-3 py-1.5 text-sm font-black text-white transition hover:bg-slate-800" type="button" data-remove-drawn="${number}">
							${number}
						</button>
					`,
				)
				.join('');
		}

		function visiblePatternIndexes(status) {
			if (currentBingoTypeKey() === 'full') return new Set();
			return new Set(status.patternIndexes);
		}

		function consideredPatternIndexes() {
			if (currentBingoTypeKey() === 'full') return new Set(ACTIVE_INDEXES);

			return new Set(
				currentBingoType()
					.patterns.flatMap((pattern) => uniquePattern(pattern))
					.filter((index) => index !== CENTER_INDEX),
			);
		}

		function renderCards() {
			const query = cardSearch.value.trim().toLowerCase();
			const drawnSet = new Set(state.drawnNumbers);
			const lastNumber = state.drawnNumbers.at(-1);
			const consideredIndexes = consideredPatternIndexes();
			const filteredCards = state.cards.filter((card) => {
				const content = `${card.id} ${card.owner}`.toLowerCase();
				return content.includes(query);
			});

			cardsSubtitle.textContent = `${filteredCards.length} de ${state.cards.length} · ${currentBingoType().label}`;
			cardsEmpty.classList.toggle('hidden', state.cards.length !== 0);
			cardsGrid.classList.toggle('hidden', state.cards.length === 0);

			cardsGrid.innerHTML = filteredCards
				.map((card) => {
					const status = cardStatus(card, drawnSet);
					const patternIndexes = visiblePatternIndexes(status);
					const cells = card.numbers
						.map((number, index) => {
							const isDisabled = index === CENTER_INDEX;
							const marked = drawnSet.has(number);
							const isLast = number === lastNumber;
							const isPattern = patternIndexes.has(index);
							const isExcluded = !isDisabled && marked && !consideredIndexes.has(index);
							const classes = ['bingo-cell'];
							if (isDisabled) classes.push('is-disabled');
							if (isExcluded) classes.push('is-excluded');
							if (isPattern) classes.push('is-pattern');
							if (!isDisabled && !isExcluded && marked) classes.push('is-marked');
							if (!isDisabled && isLast) classes.push('is-last');
							if (isDisabled) {
								return controlCellMarkup(card.id, 'is-card-cell');
							}
							return `<div class="${classes.join(' ')}">${number}</div>`;
						})
						.join('');

					return `
						<article class="rounded-lg border ${status.isBingo ? 'border-emerald-500 bg-emerald-50' : 'border-slate-200 bg-white'} p-4 shadow-sm">
							<div class="mb-3 flex items-start justify-between gap-3">
								<div class="min-w-0">
									<h3 class="truncate text-lg font-black text-slate-950">${escapeHtml(card.id)}</h3>
									<p class="truncate text-sm font-semibold text-slate-500">${escapeHtml(card.owner)}</p>
								</div>
								<span class="shrink-0 rounded-md ${status.isBingo ? 'bg-emerald-600 text-white' : 'bg-slate-100 text-slate-700'} px-3 py-1 text-sm font-black">
									${escapeHtml(status.label)}
								</span>
							</div>

							<div class="mb-2 grid grid-cols-5 gap-2 text-center text-xs font-black text-slate-500">
								${CARD_COLUMNS.map((column) => `<span>${column}</span>`).join('')}
							</div>
							<div class="grid grid-cols-5 gap-2">${cells}</div>

							<div class="mt-4 grid grid-cols-2 gap-2">
								<button class="bingo-button bingo-button-secondary" type="button" data-action="edit" data-card-id="${escapeHtml(card.id)}">
									Editar
								</button>
								<button class="bingo-button bingo-button-danger" type="button" data-action="delete" data-card-id="${escapeHtml(card.id)}">
									Eliminar
								</button>
							</div>
						</article>
					`;
				})
				.join('');

			if (state.cards.length > 0 && filteredCards.length === 0) {
				cardsGrid.innerHTML = `
					<div class="rounded-lg border border-dashed border-slate-300 bg-white p-8 text-center shadow-sm">
						<p class="text-lg font-black text-slate-900">Sin resultados</p>
					</div>
				`;
				cardsGrid.classList.remove('hidden');
			}
		}

		function showToast(card, status) {
			const toast = document.createElement('div');
			toast.className =
				'pointer-events-auto rounded-lg border border-emerald-300 bg-white p-4 text-slate-950 shadow-lg transition duration-300';
			toast.setAttribute('role', 'status');
			toast.innerHTML = `
				<div class="flex items-start gap-3">
					<div class="grid size-9 shrink-0 place-items-center rounded-md bg-emerald-600 text-sm font-black text-white">B</div>
					<div class="min-w-0">
						<p class="font-black">¡${escapeHtml(status.winLabel)}!</p>
						<p class="mt-0.5 text-sm font-semibold text-slate-600">
							${escapeHtml(card.id)} · ${escapeHtml(card.owner)}
						</p>
					</div>
				</div>
			`;

			toastRegion.append(toast);
			playBingoSound();
			window.setTimeout(() => {
				toast.classList.add('translate-y-1', 'opacity-0');
				window.setTimeout(() => toast.remove(), 300);
			}, 4500);
		}

		function syncWinnerNotifications() {
			const drawnSet = new Set(state.drawnNumbers);
			const winners = winningEntries(drawnSet);
			const currentWinningKeys = new Set(winners.map(({ card }) => winnerKey(card)));

			if (hasRendered) {
				winners.forEach(({ card, status }) => {
					if (!previousWinningKeys.has(winnerKey(card))) {
						showToast(card, status);
					}
				});
			}

			previousWinningKeys = currentWinningKeys;
			hasRendered = true;
		}

		function render() {
			renderBingoType();
			renderBingoSound();
			renderSummary();
			renderDrawnNumbers();
			renderCards();
			syncWinnerNotifications();
		}

		cardForm.addEventListener('submit', (event) => {
			event.preventDefault();
			setFormError('');

			const id = cardIdInput.value.trim();
			const owner = cardOwnerInput.value.trim();
			const rawNumbers = readCardNumbers();
			const numbers = rawNumbers.map(normalizeNumber);
			numbers[CENTER_INDEX] = null;
			const activeNumbers = ACTIVE_INDEXES.map((index) => numbers[index]);

			if (!id) {
				setFormError('Agrega el ID de la cartilla.');
				cardIdInput.focus();
				return;
			}

			if (!owner) {
				setFormError('Agrega el dueño de la cartilla.');
				cardOwnerInput.focus();
				return;
			}

			if (activeNumbers.some((number) => number === null)) {
				setFormError('Completa las 24 casillas activas con números del 1 al 75.');
				return;
			}

			const uniqueNumbers = new Set(activeNumbers);
			if (uniqueNumbers.size !== ACTIVE_CARD_SIZE) {
				setFormError('La cartilla tiene números repetidos.');
				return;
			}

			const normalizedId = id.toLowerCase();
			const idExists = state.cards.some(
				(card) => card.id.toLowerCase() === normalizedId && card.id !== editingCardId,
			);
			if (idExists) {
				setFormError('Ese ID de cartilla ya existe.');
				cardIdInput.focus();
				return;
			}

			const nextCard = {
				id,
				owner,
				numbers,
				createdAt: Date.now(),
			};

			if (editingCardId) {
				state.cards = state.cards.map((card) => (card.id === editingCardId ? nextCard : card));
			} else {
				state.cards = [nextCard, ...state.cards];
			}

			saveState();
			resetCardForm();
			render();
		});

		drawForm.addEventListener('submit', (event) => {
			event.preventDefault();
			setDrawError('');

			const number = normalizeNumber(drawNumberInput.value.trim());
			if (number === null) {
				setDrawError('Ingresa un número del 1 al 75.');
				drawNumberInput.focus();
				return;
			}

			if (state.drawnNumbers.includes(number)) {
				setDrawError('Ese número ya fue cantado.');
				drawNumberInput.select();
				return;
			}

			state.drawnNumbers = [...state.drawnNumbers, number];
			drawNumberInput.value = '';
			saveState();
			render();
			drawNumberInput.focus();
		});

		clearFormButton.addEventListener('click', resetCardForm);

		randomCardButton.addEventListener('click', () => {
			renderNumberInputs(randomCardNumbers());
			setFormError('');
		});

		cardIdInput.addEventListener('input', updateControlPreview);

		undoDrawButton.addEventListener('click', () => {
			state.drawnNumbers = state.drawnNumbers.slice(0, -1);
			saveState();
			setDrawError('');
			render();
		});

		clearDrawsButton.addEventListener('click', () => {
			if (state.drawnNumbers.length === 0) return;
			const shouldClear = window.confirm('¿Reiniciar los números cantados?');
			if (!shouldClear) return;

			state.drawnNumbers = [];
			saveState();
			setDrawError('');
			render();
		});

		drawnList.addEventListener('click', (event) => {
			const button = event.target.closest('[data-remove-drawn]');
			if (!button) return;

			const number = Number(button.dataset.removeDrawn);
			state.drawnNumbers = state.drawnNumbers.filter((drawnNumber) => drawnNumber !== number);
			saveState();
			setDrawError('');
			render();
		});

		cardsGrid.addEventListener('click', (event) => {
			const button = event.target.closest('[data-action]');
			if (!button) return;

			const action = button.dataset.action;
			const cardId = button.dataset.cardId;
			const card = state.cards.find((item) => item.id === cardId);
			if (!card) return;

			if (action === 'edit') {
				editingCardId = card.id;
				cardIdInput.value = card.id;
				cardOwnerInput.value = card.owner;
				renderNumberInputs(card.numbers);
				formTitle.textContent = 'Editar cartilla';
				saveCardButton.textContent = 'Guardar cambios';
				setFormError('');
				cardIdInput.focus();
				window.scrollTo({ top: 0, behavior: 'smooth' });
			}

			if (action === 'delete') {
				state.cards = state.cards.filter((item) => item.id !== card.id);
				if (editingCardId === card.id) resetCardForm();
				saveState();
				render();
			}
		});

		numbersGrid.addEventListener('paste', (event) => {
			const text = event.clipboardData?.getData('text') || '';
			const pastedNumbers = text.match(/\d+/g);
			if (!pastedNumbers || pastedNumbers.length <= 1) return;

			event.preventDefault();
			const inputs = Array.from(numbersGrid.querySelectorAll('input:not([disabled])'));
			const startIndex = inputs.indexOf(event.target);
			if (startIndex === -1) return;
			pastedNumbers.slice(0, ACTIVE_CARD_SIZE - startIndex).forEach((number, index) => {
				inputs[startIndex + index].value = number;
			});
		});

		customPatternGrid.addEventListener('click', (event) => {
			const button = event.target.closest('[data-custom-pattern-index]');
			if (!button) return;

			const index = Number(button.dataset.customPatternIndex);
			if (!ACTIVE_INDEXES.includes(index)) return;

			if (customPatternDraft.includes(index)) {
				customPatternDraft = customPatternDraft.filter((item) => item !== index);
			} else {
				customPatternDraft = [...customPatternDraft, index].sort((first, second) => first - second);
			}

			setCustomPatternError('');
			renderCustomPatternGrid();
		});

		customPatternModal.addEventListener('click', (event) => {
			if (!event.target.closest('[data-close-custom-pattern]')) return;
			closeCustomPatternModal();
		});

		cancelCustomPatternButton.addEventListener('click', closeCustomPatternModal);
		saveCustomPatternButton.addEventListener('click', saveCustomPattern);
		editCustomPatternButton.addEventListener('click', openCustomPatternModal);

		bingoSoundInput.addEventListener('change', async () => {
			const file = bingoSoundInput.files?.[0];
			if (!file) return;

			setBingoSoundError('');
			if (!file.type.startsWith('audio/')) {
				setBingoSoundError('Selecciona un archivo de audio.');
				bingoSoundInput.value = '';
				return;
			}

			const previousSound = state.bingoSound;
			try {
				const dataUrl = await audioFileToDataUrl(file);
				state.bingoSound = { name: file.name, dataUrl };

				if (!saveState()) {
					state.bingoSound = previousSound;
					setBingoSoundError('El audio es muy grande para guardarlo. Usa una grabación más corta.');
				}
			} catch {
				state.bingoSound = previousSound;
				setBingoSoundError('No se pudo leer el archivo de audio.');
			}

			bingoSoundInput.value = '';
			renderBingoSound();
		});

		testBingoSoundButton.addEventListener('click', () => {
			setBingoSoundError('');
			playBingoSound();
		});

		removeBingoSoundButton.addEventListener('click', () => {
			state.bingoSound = null;
			saveState();
			setBingoSoundError('');
			renderBingoSound();
		});

		openSoundStudioButton.addEventListener('click', openSoundStudio);
		startRecordingButton.addEventListener('click', startStudioRecording);
		stopRecordingButton.addEventListener('click', stopStudioRecording);
		playRecordingButton.addEventListener('click', playStudioDraft);
		resetRecordingButton.addEventListener('click', resetStudioDraft);
		cancelSoundStudioButton.addEventListener('click', closeSoundStudio);
		saveSoundStudioButton.addEventListener('click', saveSoundStudio);
		trimStartInput.addEventListener('input', () => updateStudioTrim('start'));
		trimEndInput.addEventListener('input', () => updateStudioTrim('end'));
		soundSpeedInput.addEventListener('input', updateStudioSpeed);
		studioTimelineInput.addEventListener('input', () => {
			if (!studioDraft?.dataUrl || !studioWaveformBuffer) return;
			const current = Number(studioTimelineInput.value) || 0;
			studioTimeLabel.textContent = `${formatSeconds(current)} / ${formatSeconds(studioWaveformBuffer.duration)}`;
			drawWaveform(studioWaveformBuffer, studioWaveformBuffer.duration ? current / studioWaveformBuffer.duration : 0);
			if (studioAudioSource) {
				stopStudioPlayback();
				renderSoundStudio();
			}
		});

		soundStudioModal.addEventListener('click', (event) => {
			if (!event.target.closest('[data-close-sound-studio]')) return;
			closeSoundStudio();
		});

		bingoTypeSelect.addEventListener('change', () => {
			if (bingoTypeSelect.value === CUSTOM_TYPE_KEY) {
				openCustomPatternModal();
				return;
			}

			state.bingoType = BINGO_TYPES[bingoTypeSelect.value] ? bingoTypeSelect.value : 'full';
			hasRendered = false;
			saveState();
			render();
		});

		cardSearch.addEventListener('input', renderCards);

		document.addEventListener('keydown', (event) => {
			if (event.key !== 'Escape') return;
			if (!customPatternModal.classList.contains('hidden')) {
				closeCustomPatternModal();
			}
			if (!soundStudioModal.classList.contains('hidden')) {
				closeSoundStudio();
			}
		});

		renderNumberInputs();
		render();
	</script>
</Layout>
