---
import Layout from '../layouts/Layout.astro';
import {
	Clock3,
	Gauge,
	Mic,
	Pause,
	Play,
	RotateCcw,
	Save,
	Scissors,
	Square,
	Trash2,
	Upload,
	Volume2,
	X,
} from '@lucide/astro';
---

<Layout title="Bingo Bango">
	<main class="min-h-screen bg-[#f7f4ee]">
		<header class="border-b border-slate-200 bg-white">
			<div class="mx-auto flex max-w-7xl flex-col gap-5 px-4 py-5 sm:px-6 lg:flex-row lg:items-center lg:justify-between lg:px-8">
				<div class="flex items-center gap-4">
					<div class="grid size-14 place-items-center rounded-lg bg-slate-950 text-2xl font-black text-white shadow-sm">
						B
					</div>
					<div>
						<p class="text-xs font-bold uppercase tracking-wide text-emerald-700">Mesa de control</p>
						<h1 class="text-3xl font-black text-slate-950 sm:text-4xl">Bingo Bango</h1>
					</div>
				</div>

				<div id="summary" class="grid grid-cols-3 gap-2 sm:min-w-[420px]"></div>
			</div>
		</header>

		<section class="mx-auto grid max-w-7xl gap-6 px-4 py-6 sm:px-6 lg:grid-cols-[380px_minmax(0,1fr)] lg:px-8">
			<aside class="space-y-6">
				<section class="rounded-lg border border-slate-200 bg-white p-4 shadow-sm">
					<div class="mb-4 flex items-center justify-between gap-3">
						<h2 class="text-lg font-black text-slate-950">Números cantados</h2>
						<span id="last-drawn" class="grid size-10 place-items-center rounded-md bg-amber-100 text-sm font-black text-amber-900">-</span>
					</div>

					<form id="draw-form" class="grid grid-cols-[1fr_auto] gap-2">
						<label>
							<span class="sr-only">Número cantado</span>
							<input id="draw-number" class="bingo-input" type="number" min="1" max="75" placeholder="1-75" />
						</label>
						<button class="bingo-button bingo-button-primary px-5" type="submit">Agregar</button>
					</form>

					<p id="draw-error" class="mt-3 hidden rounded-md border border-red-200 bg-red-50 px-3 py-2 text-sm font-medium text-red-700"></p>

					<div class="mt-4 grid grid-cols-2 gap-2">
						<button id="undo-draw" class="bingo-button bingo-button-secondary" type="button">Deshacer</button>
						<button id="clear-draws" class="bingo-button bingo-button-danger" type="button">Reiniciar</button>
					</div>

					<div id="drawn-list" class="mt-4 flex min-h-12 flex-wrap gap-2"></div>
				</section>

				<section class="rounded-lg border border-slate-200 bg-white p-4 shadow-sm">
					<div class="mb-4 flex items-center justify-between gap-3">
						<h2 id="form-title" class="text-lg font-black text-slate-950">Nueva cartilla</h2>
						<button id="random-card" class="bingo-button bingo-button-secondary h-9 px-3" type="button">
							Aleatoria
						</button>
					</div>

					<form id="card-form" class="space-y-4">
						<div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-1">
							<label class="space-y-1.5">
								<span class="text-sm font-semibold text-slate-700">ID cartilla</span>
								<input id="card-id" class="bingo-input" autocomplete="off" placeholder="A-001" />
							</label>

							<label class="space-y-1.5">
								<span class="text-sm font-semibold text-slate-700">Dueño</span>
								<input id="card-owner" class="bingo-input" autocomplete="off" placeholder="Nombre" />
							</label>
						</div>

						<div>
							<div class="mb-2 grid grid-cols-5 gap-2 text-center text-xs font-black text-slate-500">
								<span>B</span>
								<span>I</span>
								<span>N</span>
								<span>G</span>
								<span>O</span>
							</div>
							<div id="numbers-grid" class="grid grid-cols-5 gap-2"></div>
						</div>

						<p id="form-error" class="hidden rounded-md border border-red-200 bg-red-50 px-3 py-2 text-sm font-medium text-red-700"></p>

						<div class="grid gap-2 sm:grid-cols-2">
							<button id="save-card" class="bingo-button bingo-button-primary" type="submit">
								Guardar cartilla
							</button>
							<button id="clear-form" class="bingo-button bingo-button-secondary" type="button">
								Limpiar
							</button>
						</div>
					</form>
				</section>

				<section class="rounded-lg border border-slate-200 bg-white p-4 shadow-sm">
					<h2 class="mb-4 text-lg font-black text-slate-950">Tipo de Bingo</h2>
					<label class="space-y-1.5">
						<span class="text-sm font-semibold text-slate-700">Figura ganadora</span>
						<select id="bingo-type" class="bingo-input">
							<option value="full">Cartilla completa</option>
							<option value="line">Linea</option>
							<option value="t">Letra T</option>
							<option value="n">Letra N</option>
							<option value="x">Letra X</option>
							<option value="corners">Cuatro esquinas</option>
							<option value="frame">Marco</option>
							<option value="custom">Personalizado</option>
						</select>
					</label>

					<div class="mt-4">
						<div class="mb-2 flex items-center justify-between gap-3">
							<span id="bingo-type-label" class="text-sm font-black text-slate-900"></span>
							<span id="bingo-type-requirement" class="text-xs font-bold uppercase tracking-wide text-slate-500"></span>
						</div>
						<div id="pattern-preview" class="grid max-w-44 grid-cols-5 gap-1"></div>
					</div>

					<button id="edit-custom-pattern" class="bingo-button bingo-button-secondary mt-4 hidden w-full" type="button">
						Editar figura
					</button>

					<div class="mt-5 border-t border-slate-200 pt-4">
						<h3 class="text-sm font-black text-slate-950">Sonido de Bingo</h3>
						<p id="bingo-sound-status" class="mt-1 truncate text-sm font-semibold text-slate-500"></p>
						<input id="bingo-sound-input" class="sr-only" type="file" accept="audio/*" />
						<p id="bingo-sound-error" class="mt-2 hidden rounded-md border border-red-200 bg-red-50 px-3 py-2 text-sm font-medium text-red-700"></p>
						<div class="mt-3 grid grid-cols-2 gap-2">
							<label class="bingo-button bingo-button-secondary cursor-pointer" for="bingo-sound-input">
								<Upload size={16} aria-hidden="true" />
								<span>Cargar</span>
							</label>
							<button id="open-sound-studio" class="bingo-button bingo-button-secondary" type="button">
								<Mic size={16} aria-hidden="true" />
								<span>Crear</span>
							</button>
							<button id="test-bingo-sound" class="bingo-button bingo-button-secondary" type="button">
								<Volume2 size={16} aria-hidden="true" />
								<span>Probar</span>
							</button>
							<button id="remove-bingo-sound" class="bingo-button bingo-button-danger" type="button">
								<Trash2 size={16} aria-hidden="true" />
								<span>Quitar</span>
							</button>
						</div>
					</div>
				</section>
			</aside>

			<section class="min-w-0 space-y-4">
				<div class="flex flex-col gap-3 rounded-lg border border-slate-200 bg-white p-4 shadow-sm sm:flex-row sm:items-center sm:justify-between">
					<div>
						<h2 class="text-xl font-black text-slate-950">Cartillas</h2>
						<p id="cards-subtitle" class="text-sm font-medium text-slate-500"></p>
					</div>
					<label class="sm:w-72">
						<span class="sr-only">Buscar cartilla</span>
						<input id="card-search" class="bingo-input" autocomplete="off" placeholder="Buscar por ID o dueño" />
					</label>
				</div>

				<div id="cards-empty" class="rounded-lg border border-dashed border-slate-300 bg-white p-8 text-center shadow-sm">
					<p class="text-lg font-black text-slate-900">Sin cartillas</p>
					<p class="mt-1 text-sm font-medium text-slate-500">Registra la primera cartilla para empezar.</p>
				</div>

				<div id="cards-grid" class="grid gap-4 xl:grid-cols-2"></div>
			</section>
		</section>
	</main>

	<div id="toast-region" class="pointer-events-none fixed right-4 top-4 z-50 flex w-[min(360px,calc(100vw-2rem))] flex-col gap-3"></div>

	<div id="custom-pattern-modal" class="fixed inset-0 z-40 hidden flex items-center justify-center p-4">
		<button class="absolute inset-0 bg-slate-950/50" type="button" data-close-custom-pattern aria-label="Cerrar"></button>
		<section class="relative w-full max-w-md rounded-lg border border-slate-200 bg-white p-5 shadow-xl" role="dialog" aria-modal="true" aria-labelledby="custom-pattern-title">
			<div class="mb-4 flex items-center justify-between gap-3">
				<h2 id="custom-pattern-title" class="text-xl font-black text-slate-950">Figura personalizada</h2>
				<button class="bingo-button bingo-button-secondary size-9 px-0" type="button" data-close-custom-pattern aria-label="Cerrar">
					X
				</button>
			</div>

			<div class="mb-2 grid grid-cols-5 gap-2 text-center text-xs font-black text-slate-500">
				<span>B</span>
				<span>I</span>
				<span>N</span>
				<span>G</span>
				<span>O</span>
			</div>
			<div id="custom-pattern-grid" class="grid grid-cols-5 gap-2"></div>

			<div class="mt-4 flex items-center justify-between gap-3">
				<span id="custom-pattern-count" class="text-sm font-black text-slate-700"></span>
				<p id="custom-pattern-error" class="hidden text-sm font-semibold text-red-700"></p>
			</div>

			<div class="mt-5 grid gap-2 sm:grid-cols-2">
				<button id="cancel-custom-pattern" class="bingo-button bingo-button-secondary" type="button">Cancelar</button>
				<button id="save-custom-pattern" class="bingo-button bingo-button-primary" type="button">Guardar figura</button>
			</div>
		</section>
	</div>

	<div id="sound-studio-modal" class="fixed inset-0 z-40 hidden flex items-center justify-center p-4">
		<button class="absolute inset-0 bg-slate-950/50" type="button" data-close-sound-studio aria-label="Cerrar"></button>
		<section class="relative w-full max-w-2xl rounded-lg border border-slate-200 bg-white p-5 shadow-xl" role="dialog" aria-modal="true" aria-labelledby="sound-studio-title">
			<div class="mb-4 flex items-center justify-between gap-3">
				<h2 id="sound-studio-title" class="text-xl font-black text-slate-950">Crear sonido de Bingo</h2>
				<button class="bingo-button bingo-button-secondary size-9 px-0" type="button" data-close-sound-studio aria-label="Cerrar">
					<X size={18} aria-hidden="true" />
				</button>
			</div>

			<div class="rounded-lg border border-slate-200 bg-slate-50 p-4">
				<div class="flex items-start justify-between gap-4">
					<div class="min-w-0">
						<p id="sound-studio-status" class="text-sm font-black text-slate-800"></p>
						<p id="sound-studio-detail" class="mt-1 text-sm font-semibold text-slate-500"></p>
					</div>
					<span id="studio-time-label" class="shrink-0 rounded-md bg-white px-3 py-1 text-sm font-black text-slate-700 shadow-sm">0.0s</span>
				</div>

				<div class="mt-4 rounded-md border border-slate-200 bg-white p-3">
					<canvas id="sound-waveform" class="h-28 w-full" width="720" height="160"></canvas>
					<input id="studio-timeline" class="sound-range mt-3" type="range" min="0" max="0" step="0.05" value="0" disabled />
				</div>

				<div class="mt-4 grid gap-2 sm:grid-cols-4">
					<button id="start-recording" class="sound-tool-button is-primary" type="button">
						<Mic size={18} aria-hidden="true" />
						<span>Grabar</span>
					</button>
					<button id="stop-recording" class="sound-tool-button" type="button">
						<Square size={18} aria-hidden="true" />
						<span>Detener</span>
					</button>
					<button id="play-recording" class="sound-tool-button" type="button">
						<Play id="play-recording-icon" size={18} aria-hidden="true" />
						<Pause id="pause-recording-icon" class="hidden" size={18} aria-hidden="true" />
						<span id="play-recording-label">Reproducir</span>
					</button>
					<button id="reset-recording" class="sound-tool-button is-danger" type="button">
						<RotateCcw size={18} aria-hidden="true" />
						<span>Reiniciar</span>
					</button>
				</div>
			</div>

			<div class="mt-5 space-y-4">
				<label class="space-y-2">
					<div class="flex items-center justify-between gap-3">
						<span class="inline-flex items-center gap-2 text-sm font-black text-slate-800">
							<Scissors size={16} aria-hidden="true" />
							Inicio
						</span>
						<span id="trim-start-label" class="text-sm font-semibold text-slate-500">0.0s</span>
					</div>
					<input id="trim-start" class="sound-range" type="range" min="0" max="0" step="0.05" value="0" disabled />
				</label>

				<label class="space-y-2">
					<div class="flex items-center justify-between gap-3">
						<span class="inline-flex items-center gap-2 text-sm font-black text-slate-800">
							<Clock3 size={16} aria-hidden="true" />
							Fin
						</span>
						<span id="trim-end-label" class="text-sm font-semibold text-slate-500">0.0s</span>
					</div>
					<input id="trim-end" class="sound-range" type="range" min="0" max="0" step="0.05" value="0" disabled />
				</label>

				<label class="space-y-2">
					<div class="flex items-center justify-between gap-3">
						<span class="inline-flex items-center gap-2 text-sm font-black text-slate-800">
							<Gauge size={16} aria-hidden="true" />
							Velocidad
						</span>
						<span id="sound-speed-label" class="text-sm font-semibold text-slate-500">1.00x</span>
					</div>
					<input id="sound-speed" class="sound-range" type="range" min="0.5" max="1.8" step="0.05" value="1" disabled />
				</label>
			</div>

			<p id="sound-studio-error" class="mt-4 hidden rounded-md border border-red-200 bg-red-50 px-3 py-2 text-sm font-medium text-red-700"></p>

			<div class="mt-5 grid gap-2 sm:grid-cols-2">
				<button id="cancel-sound-studio" class="bingo-button bingo-button-secondary" type="button">Cancelar</button>
				<button id="save-sound-studio" class="bingo-button bingo-button-primary" type="button">
					<Save size={16} aria-hidden="true" />
					<span>Guardar sonido</span>
				</button>
			</div>
		</section>
	</div>

	<script>
		const STORAGE_KEY = 'bingo-bango-state-v1';
		const CUSTOM_TYPE_KEY = 'custom';
		const DEFAULT_BINGO_SOUND = {
			name: 'bingo.mp3',
			src: '/bingo.mp3',
		};
		const CARD_SIZE = 25;
		const ACTIVE_CARD_SIZE = 24;
		const CENTER_INDEX = 12;
		const CARD_COLUMNS = ['B', 'I', 'N', 'G', 'O'];
		const ALL_INDEXES = Array.from({ length: CARD_SIZE }, (_, index) => index);
		const ACTIVE_INDEXES = ALL_INDEXES.filter((index) => index !== CENTER_INDEX);
		const activePattern = (pattern) => pattern.filter((index) => index !== CENTER_INDEX);
		const FULL_PATTERN = ACTIVE_INDEXES;
		const ROW_PATTERNS = Array.from({ length: 5 }, (_, row) =>
			activePattern(Array.from({ length: 5 }, (_, column) => row * 5 + column)),
		);
		const COLUMN_PATTERNS = Array.from({ length: 5 }, (_, column) =>
			activePattern(Array.from({ length: 5 }, (_, row) => row * 5 + column)),
		);
		const DIAGONAL_PATTERNS = [
			activePattern([0, 6, 12, 18, 24]),
			activePattern([4, 8, 12, 16, 20]),
		];
		const DEFAULT_CUSTOM_PATTERN = activePattern([0, 1, 2, 3, 4]);
		const BINGO_TYPES = {
			full: {
				label: 'Cartilla completa',
				winLabel: 'Bingo completo',
				patterns: [FULL_PATTERN],
			},
			line: {
				label: 'Linea',
				winLabel: 'Bingo en linea',
				patterns: [...ROW_PATTERNS, ...COLUMN_PATTERNS, ...DIAGONAL_PATTERNS],
			},
			t: {
				label: 'Letra T',
				winLabel: 'Bingo T',
				patterns: [activePattern([0, 1, 2, 3, 4, 7, 12, 17, 22])],
			},
			n: {
				label: 'Letra N',
				winLabel: 'Bingo N',
				patterns: [activePattern([0, 5, 10, 15, 20, 6, 12, 18, 4, 9, 14, 19, 24])],
			},
			x: {
				label: 'Letra X',
				winLabel: 'Bingo X',
				patterns: [activePattern([0, 6, 12, 18, 24, 4, 8, 16, 20])],
			},
			corners: {
				label: 'Cuatro esquinas',
				winLabel: 'Bingo en esquinas',
				patterns: [[0, 4, 20, 24]],
			},
			frame: {
				label: 'Marco',
				winLabel: 'Bingo marco',
				patterns: [[0, 1, 2, 3, 4, 5, 9, 10, 14, 15, 19, 20, 21, 22, 23, 24]],
			},
			[CUSTOM_TYPE_KEY]: {
				label: 'Personalizado',
				winLabel: 'Bingo personalizado',
				patterns: [DEFAULT_CUSTOM_PATTERN],
			},
		};

		const summary = document.querySelector('#summary');
		const cardForm = document.querySelector('#card-form');
		const formTitle = document.querySelector('#form-title');
		const saveCardButton = document.querySelector('#save-card');
		const clearFormButton = document.querySelector('#clear-form');
		const randomCardButton = document.querySelector('#random-card');
		const cardIdInput = document.querySelector('#card-id');
		const cardOwnerInput = document.querySelector('#card-owner');
		const numbersGrid = document.querySelector('#numbers-grid');
		const formError = document.querySelector('#form-error');
		const drawForm = document.querySelector('#draw-form');
		const drawNumberInput = document.querySelector('#draw-number');
		const drawError = document.querySelector('#draw-error');
		const drawnList = document.querySelector('#drawn-list');
		const lastDrawn = document.querySelector('#last-drawn');
		const undoDrawButton = document.querySelector('#undo-draw');
		const clearDrawsButton = document.querySelector('#clear-draws');
		const cardsGrid = document.querySelector('#cards-grid');
		const cardsEmpty = document.querySelector('#cards-empty');
		const cardsSubtitle = document.querySelector('#cards-subtitle');
		const cardSearch = document.querySelector('#card-search');
		const bingoTypeSelect = document.querySelector('#bingo-type');
		const bingoTypeLabel = document.querySelector('#bingo-type-label');
		const bingoTypeRequirement = document.querySelector('#bingo-type-requirement');
		const patternPreview = document.querySelector('#pattern-preview');
		const editCustomPatternButton = document.querySelector('#edit-custom-pattern');
		const toastRegion = document.querySelector('#toast-region');
		const bingoSoundInput = document.querySelector('#bingo-sound-input');
		const bingoSoundStatus = document.querySelector('#bingo-sound-status');
		const bingoSoundError = document.querySelector('#bingo-sound-error');
		const openSoundStudioButton = document.querySelector('#open-sound-studio');
		const testBingoSoundButton = document.querySelector('#test-bingo-sound');
		const removeBingoSoundButton = document.querySelector('#remove-bingo-sound');
		const customPatternModal = document.querySelector('#custom-pattern-modal');
		const customPatternGrid = document.querySelector('#custom-pattern-grid');
		const customPatternCount = document.querySelector('#custom-pattern-count');
		const customPatternError = document.querySelector('#custom-pattern-error');
		const cancelCustomPatternButton = document.querySelector('#cancel-custom-pattern');
		const saveCustomPatternButton = document.querySelector('#save-custom-pattern');
		const soundStudioModal = document.querySelector('#sound-studio-modal');
		const soundStudioStatus = document.querySelector('#sound-studio-status');
		const soundStudioDetail = document.querySelector('#sound-studio-detail');
		const soundStudioError = document.querySelector('#sound-studio-error');
		const soundWaveformCanvas = document.querySelector('#sound-waveform');
		const studioTimelineInput = document.querySelector('#studio-timeline');
		const studioTimeLabel = document.querySelector('#studio-time-label');
		const startRecordingButton = document.querySelector('#start-recording');
		const stopRecordingButton = document.querySelector('#stop-recording');
		const playRecordingButton = document.querySelector('#play-recording');
		const playRecordingIcon = document.querySelector('#play-recording-icon');
		const pauseRecordingIcon = document.querySelector('#pause-recording-icon');
		const playRecordingLabel = document.querySelector('#play-recording-label');
		const resetRecordingButton = document.querySelector('#reset-recording');
		const trimStartInput = document.querySelector('#trim-start');
		const trimEndInput = document.querySelector('#trim-end');
		const trimStartLabel = document.querySelector('#trim-start-label');
		const trimEndLabel = document.querySelector('#trim-end-label');
		const soundSpeedInput = document.querySelector('#sound-speed');
		const soundSpeedLabel = document.querySelector('#sound-speed-label');
		const cancelSoundStudioButton = document.querySelector('#cancel-sound-studio');
		const saveSoundStudioButton = document.querySelector('#save-sound-studio');

		let editingCardId = null;
		let state = loadState();
		let hasRendered = false;
		let previousWinningKeys = new Set();
		let customPatternDraft = [];
		let studioRecorder = null;
		let studioStream = null;
		let studioChunks = [];
		let studioDraft = null;
		let studioAudioContext = null;
		let studioAudioSource = null;
		let studioWaveformBuffer = null;
		let studioAnalyser = null;
		let studioMeterSource = null;
		let studioMeterAnimation = null;
		let studioPlaybackAnimation = null;
		let studioIsProcessing = false;
		let studioRecordingStartedAt = 0;
		let studioPlaybackStartedAt = 0;
		let studioPlaybackStart = 0;
		let studioPlaybackDuration = 0;

		function loadState() {
			try {
				const saved = JSON.parse(localStorage.getItem(STORAGE_KEY) || '{}');
				return {
					cards: Array.isArray(saved.cards) ? saved.cards.map(normalizeCard) : [],
					drawnNumbers: Array.isArray(saved.drawnNumbers) ? saved.drawnNumbers : [],
					bingoType: BINGO_TYPES[saved.bingoType] ? saved.bingoType : 'full',
					customPattern: normalizeCustomPattern(saved.customPattern),
					bingoSound: normalizeBingoSound(saved.bingoSound),
				};
			} catch {
				return {
					cards: [],
					drawnNumbers: [],
					bingoType: 'full',
					customPattern: DEFAULT_CUSTOM_PATTERN,
					bingoSound: null,
				};
			}
		}

		function saveState() {
			try {
				localStorage.setItem(STORAGE_KEY, JSON.stringify(state));
				return true;
			} catch {
				return false;
			}
		}

		function normalizeCustomPattern(pattern) {
			const indexes = Array.isArray(pattern) ? pattern : DEFAULT_CUSTOM_PATTERN;
			const cleanIndexes = uniquePattern(indexes)
				.map((index) => Number(index))
				.filter((index) => ACTIVE_INDEXES.includes(index));

			return cleanIndexes.length > 0 ? cleanIndexes : [...DEFAULT_CUSTOM_PATTERN];
		}

		function normalizeBingoSound(sound) {
			if (!sound || typeof sound !== 'object') return null;
			const name = String(sound.name ?? '').trim();
			const dataUrl = String(sound.dataUrl ?? '');
			if (!name || !dataUrl.startsWith('data:audio/')) return null;

			const normalized = {
				name,
				dataUrl,
				kind: sound.kind === 'recorded' ? 'recorded' : 'file',
			};
			const duration = Number(sound.duration);
			const trimStart = Number(sound.trimStart);
			const trimEnd = Number(sound.trimEnd);
			const playbackRate = Number(sound.playbackRate);

			if (Number.isFinite(duration) && duration > 0) {
				normalized.duration = duration;
			}
			if (Number.isFinite(trimStart) && trimStart >= 0) {
				normalized.trimStart = trimStart;
			}
			if (Number.isFinite(trimEnd) && trimEnd > 0) {
				normalized.trimEnd = trimEnd;
			}
			if (Number.isFinite(playbackRate) && playbackRate > 0) {
				normalized.playbackRate = playbackRate;
			}

			return normalized;
		}

		function effectiveBingoSound() {
			const customSound = normalizeBingoSound(state.bingoSound);
			return customSound ?? DEFAULT_BINGO_SOUND;
		}

		function normalizeCard(card) {
			const sourceNumbers = Array.isArray(card.numbers) ? [...card.numbers] : [];
			if (sourceNumbers.length === ACTIVE_CARD_SIZE) {
				sourceNumbers.splice(CENTER_INDEX, 0, null);
			}

			const numbers = ALL_INDEXES.map((index) =>
				index === CENTER_INDEX ? null : normalizeNumber(sourceNumbers[index]),
			);

			return {
				...card,
				id: String(card.id ?? ''),
				owner: String(card.owner ?? ''),
				numbers,
			};
		}

		function escapeHtml(value) {
			return String(value).replace(/[&<>"']/g, (character) => {
				const entities = {
					'&': '&amp;',
					'<': '&lt;',
					'>': '&gt;',
					'"': '&quot;',
					"'": '&#039;',
				};
				return entities[character];
			});
		}

		function controlCardId(id) {
			return id.trim() || 'ID cartilla';
		}

		function controlCellMarkup(id, className = '') {
			return `
				<div class="bingo-control-cell ${className}" aria-label="Casilla central de control">
					<span>CONTROL</span>
